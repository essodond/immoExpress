{
  "name": "immoexpert",
  "version": "1.0.0",
  "description": "Plateforme complète de gestion immobilière avec interface admin et catalogue public responsive",
  "private": true,
  "license": "MIT",
  "author": "ImmoExpert Team",
  "keywords": [
    "immobilier",
    "real-estate",
    "gestion",
    "management",
    "Next.js",
    "React",
    "TypeScript",
    "Admin",
    "Dashboard"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "clean": "rimraf frontend/node_modules backend/node_modules frontend/.next backend/dist"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/immo.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/immo/issues"
  },
  "homepage": "https://github.com/yourusername/immo#readme"
}

